FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache ffmpeg

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./tsconfig.json
COPY src ./src
COPY scripts ./scripts
COPY config ./config

ENV NODE_ENV=production
ENV MEDIA_WORKER_PORT=3101

EXPOSE 3101

CMD ["npx", "tsx", "scripts/media-worker-server.ts"]
