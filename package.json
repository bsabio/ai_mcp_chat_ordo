{
  "name": "studio-ordo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "npm run validate:env",
    "dev": "node scripts/dev.mjs",
    "prebuild": "npm run build:search-index",
    "build": "next build",
    "build:search-index": "tsx scripts/build-search-index.ts",
    "build:search-index:force": "tsx scripts/build-search-index.ts --force",
    "release:prepare": "npm run build && node scripts/generate-release-manifest.mjs",
    "release:verify": "node scripts/validate-release-manifest.mjs",
    "run": "npm run release:verify && npm run start",
    "start": "node scripts/start-server.mjs",
    "lint": "eslint",
    "lint:css": "stylelint \"src/app/**/*.css\"",
    "spacing:audit": "node scripts/spacing-audit.js --threshold=0",
    "spacing:audit:report": "node scripts/spacing-audit.js --report-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser-ui": "vitest run tests/browser-support.test.ts tests/browser-overlays.test.tsx tests/browser-motion.test.tsx tests/browser-api-fallbacks.test.ts tests/browser-fab-chat-flow.test.tsx tests/browser-fab-scroll-recovery.test.tsx tests/browser-fab-mobile-density.test.tsx tests/browser-graph-interactions.test.tsx tests/browser-graph-rendering.test.tsx tests/browser-graph-data-preview.test.tsx src/components/AudioPlayer.test.tsx",
    "test:browser-live": "playwright test tests/browser-ui/fab-live-smoke.spec.ts tests/browser-ui/jobs-page.spec.ts tests/browser-ui/admin-jobs.spec.ts tests/browser-ui/deferred-blog-jobs.spec.ts tests/browser-ui/admin-shell-responsive.spec.ts",
    "test:homepage-shell": "vitest run tests/homepage-shell-ownership.test.tsx tests/homepage-shell-layout.test.tsx src/hooks/useMessageScrollBoundaryLock.test.tsx",
    "test:homepage-evals": "vitest run tests/homepage-shell-evals.test.tsx",
    "validate:env": "tsx scripts/validate-env.ts",
    "admin:validate-env": "tsx scripts/admin-validate-env.ts",
    "admin:health": "tsx scripts/admin-health-sweep.ts",
    "admin:diagnostics": "tsx scripts/admin-diagnostics.ts",
    "admin:reap-chat-uploads": "tsx scripts/reap-chat-uploads.ts",
    "jobs:work": "tsx scripts/process-deferred-jobs.ts",
    "live:blog-pipeline": "tsx scripts/run-live-blog-pipeline.ts",
    "push:vapid": "tsx scripts/generate-web-push-vapid.ts",
    "repair:conversation-indexes": "tsx scripts/repair-conversation-indexes.ts",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "check:stateless": "node scripts/assert-stateless-runtime.mjs",
    "parity:env": "node scripts/validate-env-parity.mjs",
    "mcp:calculator": "tsx mcp/calculator-server.ts",
    "mcp:embeddings": "tsx mcp/embedding-server.ts",
    "eval:live": "tsx scripts/run-live-eval.ts",
    "eval:staging-canary": "tsx scripts/run-staging-canary.ts",
    "eval:deployed-canary": "tsx scripts/run-staging-canary.ts",
    "release:evidence": "tsx scripts/generate-release-evidence.ts",
    "qa:sprint-3": "tsx scripts/run-sprint-3-qa.ts",
    "qa:sprint-4": "tsx scripts/run-sprint-4-qa.ts",
    "qa:sprint-6": "tsx scripts/run-sprint-6-qa.ts",
    "qa:roles": "vitest run tests/core-policy.test.ts tests/tool-registry.integration.test.ts tests/customer-workflow-evals.test.ts src/app/dashboard/page.test.tsx",
    "typecheck": "tsc --noEmit",
    "lint:strict": "eslint --max-warnings 0",
    "quality": "npm run typecheck && npm run lint:strict && npm run lint:css && npm run spacing:audit && npm run test",
    "browser:verify": "npm run test:browser-ui && npm run test:homepage-shell",
    "browser:smoke": "npm run test:browser-live",
    "browser:verify:quality": "npm run browser:verify && npm run build && echo 'Run npm run lhci against the production target to compare with lighthouse-prod.json.'",
    "lhci": "lhci autorun",
    "lhci:dev": "lhci collect --url=http://localhost:3000 && lhci assert",
    "llm_export": "tsx scripts/llm-export.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "mermaid": "^11.12.3",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^28.1.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
